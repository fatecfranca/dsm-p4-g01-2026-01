// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Telemetria {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  dispositivoId    String   // Ex: "ESP32_SALA_01" ou MAC Address
  voltagem         Float    // Tensão instantânea em Volts (V)
  corrente         Float    // Corrente instantânea em Amperes (A)
  potenciaAtiva    Float    // O que realmente gera trabalho (Watts)
  potenciaAparente Float?   // Voltagem * Corrente (VA)
  potenciaReativa  Float?   // Energia "perdida" em motores/indutores (VAR)
  fatorPotencia    Float?   // Eficiência do uso da energia (de 0.0 a 1.0)
  frequencia       Float?   // Frequência da rede (Hz) - ideal 60Hz
  potenciaKw       Float?   // Potência instantânea em kW (potenciaAtiva / 1000)
  custoHora        Float?   // Cesto por hora ao ritmo atual (potenciaKw * tarifa)
  timestamp        DateTime @default(now()) // Tempo exato da leitura
}

model Usuario {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
}
